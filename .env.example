DATABASE_URL="file:./dev.db"

# --- 포인핸드 브리지 동기화 (선택) ---
# 기본: 내장 17개 시·도 × 축종 개·고양이·기타 를 순회합니다. (city=전체 는 빈 목록이 될 수 있음)
# PAWINHAND_BRIDGE_BASE_URL="https://pawinhand.net"
# PAWINHAND_BRIDGE_CITIES="서울특별시,부산광역시,광주광역시,..."
# PAWINHAND_BRIDGE_SPECIES_LIST="개,고양이,기타"
# PAWINHAND_BRIDGE_MAX_PAGES_PER_QUERY=8
# PAWINHAND_BRIDGE_REQUEST_DELAY_MS=120
# PAWINHAND_BRIDGE_COUNTRY="전체"
# PAWINHAND_BRIDGE_BREEDS="전체"
# PAWINHAND_BRIDGE_STATE="전체"
# PAWINHAND_BRIDGE_SEX="전체"
# PAWINHAND_BRIDGE_NEUTRAL="전체"
# PAWINHAND_BRIDGE_LOOKBACK_MONTHS=3
# PAWINHAND_BRIDGE_LIMIT=20

# --- 국가동물보호정보시스템(AWTIS) HTML 크롤링 (선택) ---
# AWTIS_LIST_URL="https://www.animal.go.kr/front/awtis/public/publicList.do"
# AWTIS_MENU_NO="1000000055"
# AWTIS_CRAWL_DELAY_MS=450
# AWTIS_MAX_LIST_PAGES=3
# AWTIS_MAX_DETAILS_PER_RUN=40
# AWTIS_USER_AGENT="FindMyFriend/1.0"
# 시·도+시군구 한 줄 → searchOrgCd (JSON). 동일 키는 아래 내장 예시보다 우선합니다.
# 예: {"경상남도 거창":"5470000","서울 강남구":"3220000"}
# AWTIS_ORG_MAP_JSON="{}"

# --- Discord 알림 (Incoming Webhook) ---
# 디스코드 서버 → 채널 설정 → 연동 → 웹후크 만들기 → 웹후크 URL 복사
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/숫자/토큰"
# 선택: 채널에 보이는 봇 이름·아바타 (비우면 웹훅 기본값). 아바타는 반드시 http(s) URL 한 줄만.
# 잘못된 예: 한 줄에 키=값 이어 붙이기, 따옴표 안에 키 이름 넣기
# DISCORD_WEBHOOK_USERNAME="findMyFriend"
# DISCORD_WEBHOOK_AVATAR_URL="https://cdn.discordapp.com/embed/avatars/0.png"
# 선택: 알림 임베드에 넣을 앱 상세 링크 접두 (예: https://your-domain.com 또는 http://localhost:3000)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- 네이버 카페(구피사랑) 크롤 · 카페 전용 Discord (선택) ---
# 세션 파일은 npm run naver-cafe:login 로 생성 (기본 경로 storage/naver-session.json)
# NAVER_SESSION_PATH="storage/naver-session.json"
# 메뉴 자동 클릭이 실패하면 게시판 목록 URL을 JSON으로 지정
# NAVER_CAFE_BOARD_URLS_JSON='{"love_share":"https://..."}'
# headless 끄려면 false
# NAVER_CAFE_HEADLESS="true"
# 진행 로그 끄려면 0 (기본: 켜짐)
# NAVER_CAFE_DEBUG="0"
# 카페 알림만 다른 웹훅으로 쏠 때 (비우면 DISCORD_WEBHOOK_URL 사용)
# DISCORD_CAFE_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# API 보호 (비우면 로컬에서 인증 없이 POST 허용)
# CRON_SECRET=""
