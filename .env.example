DATABASE_URL="file:./dev.db"

# --- 포인핸드 브리지 동기화 (선택) ---
# 기본: 내장 17개 시·도 × 축종 개·고양이·기타 를 순회합니다. (city=전체 는 빈 목록이 될 수 있음)
# PAWINHAND_BRIDGE_BASE_URL="https://pawinhand.net"
# PAWINHAND_BRIDGE_CITIES="서울특별시,부산광역시,광주광역시,..."
# PAWINHAND_BRIDGE_SPECIES_LIST="개,고양이,기타"
# PAWINHAND_BRIDGE_MAX_PAGES_PER_QUERY=8
# PAWINHAND_BRIDGE_REQUEST_DELAY_MS=120
# PAWINHAND_BRIDGE_COUNTRY="전체"
# PAWINHAND_BRIDGE_BREEDS="전체"
# PAWINHAND_BRIDGE_STATE="전체"
# PAWINHAND_BRIDGE_SEX="전체"
# PAWINHAND_BRIDGE_NEUTRAL="전체"
# PAWINHAND_BRIDGE_LOOKBACK_MONTHS=3
# PAWINHAND_BRIDGE_LIMIT=20

# --- Discord 알림 (Incoming Webhook) ---
# 디스코드 서버 → 채널 설정 → 연동 → 웹후크 만들기 → 웹후크 URL 복사
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/숫자/토큰"
# 선택: 채널에 보이는 봇 이름·아바타 (비우면 웹훅 기본값). 아바타는 반드시 http(s) URL 한 줄만.
# 잘못된 예: 한 줄에 키=값 이어 붙이기, 따옴표 안에 키 이름 넣기
# DISCORD_WEBHOOK_USERNAME="findMyFriend"
# DISCORD_WEBHOOK_AVATAR_URL="https://cdn.discordapp.com/embed/avatars/0.png"
# 선택: 알림 임베드에 넣을 앱 상세 링크 접두 (예: https://your-domain.com 또는 http://localhost:3000)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
