generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Animal {
  id             Int        @id @default(autoincrement())
  sourceSite     String     @map("source_site")
  noticeNo       String     @map("notice_no")
  status         String
  category       String
  breed          String
  gender         String
  neutered       String
  foundLocation  String     @map("found_location")
  foundRegion    String     @map("found_region")
  foundDate      DateTime   @map("found_date")
  noticeStartAt  DateTime?  @map("notice_start_at")
  noticeEndAt    DateTime?  @map("notice_end_at")
  features       String
  imageUrl       String     @map("image_url")
  /** JSON 배열 문자열: ["https://...", ...] — 상세 갤러리·추가 사진 */
  imageGallery   String     @default("[]") @map("image_gallery")
  detailUrl      String     @map("detail_url")
  shelterId      Int        @map("shelter_id")
  shelter        Shelter        @relation(fields: [shelterId], references: [id])
  sources        AnimalSource[]
  alertLogs      AlertLog[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@unique([sourceSite, noticeNo])
  @@index([foundRegion])
  @@index([foundDate])
  @@map("animals")
}

/** 동일 개체가 포인핸드·AWTIS 등 여러 플랫폼에 올라온 경우 링크를 모두 보관 */
model AnimalSource {
  id                 Int    @id @default(autoincrement())
  animalId           Int    @map("animal_id")
  animal             Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  /** pawinhand | awtis */
  sourceType         String @map("source_type")
  sourceUrl          String @map("source_url")
  sourceNoticeNo     String? @map("source_notice_no")
  sourceDesertionNo  String? @map("source_desertion_no")

  @@unique([animalId, sourceType])
  @@index([sourceType])
  @@map("animal_sources")
}

model Shelter {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  address   String
  website   String
  animals   Animal[]

  @@map("shelters")
}

model User {
  id            Int         @id @default(autoincrement())
  /** 물리 컬럼명은 기존 `email` (마이그레이션 호환). 값은 UUID 등 구독 식별자만 저장합니다. */
  subscriberKey String      @unique @map("email")
  displayName   String?     @map("display_name")
  password      String?
  alerts        UserAlert[]
  alertLogs     AlertLog[]
  cafeAlerts    CafeUserAlert[]
  cafeAlertLogs CafeAlertLog[]
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("users")
}

model UserAlert {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  label           String?
  category        String?
  breed           String?
  region          String?
  gender          String?
  neutered        String?
  featureKeywords String   @map("feature_keywords")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("user_alerts")
}

model AlertLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  animalId     Int      @map("animal_id")
  animal       Animal   @relation(fields: [animalId], references: [id])
  matchedScore Int      @map("matched_score")
  sentAt       DateTime @default(now()) @map("sent_at")

  @@unique([userId, animalId])
  @@map("alert_logs")
}

/** 네이버 카페(구피사랑 등)에서 수집한 게시글 — url 기준 중복 방지 */
model CafeCrawledPost {
  id               Int            @id @default(autoincrement())
  url              String         @unique
  title            String
  boardKey         String         @map("board_key")
  boardLabel       String         @map("board_label")
  /** sharing | trade | unknown */
  postKind         String         @map("post_kind")
  /** 제목 앞 [지역] 등 */
  titleRegion      String?        @map("title_region")
  /** 분양글 앞 [판매중] 등 */
  tradeStatus      String?        @map("trade_status")
  thumbnailUrl     String?        @map("thumbnail_url")
  contentSnippet   String?        @map("content_snippet")
  postedAt         DateTime?      @map("posted_at")
  firstSeenAt      DateTime       @default(now()) @map("first_seen_at")
  cafeAlertLogs    CafeAlertLog[]

  @@index([boardKey])
  @@index([firstSeenAt])
  @@map("cafe_crawled_posts")
}

/** 네이버 카페 분양/나눔 알림 조건 */
model CafeUserAlert {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label               String?
  /** JSON string[] — 감시할 게시판 키 */
  boardKeysJson       String   @map("board_keys_json")
  /** any | sharing | trade */
  listingKind         String   @default("any") @map("listing_kind")
  /** JSON string[] — 비우면 지역 무관 */
  regionsJson         String   @map("regions_json")
  /** JSON string[] — 각 문자열은 띄어쓰기로 토큰 분리 후 AND 매칭 */
  keywordPhrasesJson  String   @map("keyword_phrases_json")
  createdAt           DateTime @default(now()) @map("created_at")
  cafeAlertLogs       CafeAlertLog[]

  @@map("cafe_user_alerts")
}

model CafeAlertLog {
  id        Int             @id @default(autoincrement())
  userId    Int             @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertId   Int             @map("alert_id")
  alert     CafeUserAlert   @relation(fields: [alertId], references: [id], onDelete: Cascade)
  postId    Int             @map("post_id")
  post      CafeCrawledPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  sentAt    DateTime        @default(now()) @map("sent_at")

  @@unique([userId, postId])
  @@map("cafe_alert_logs")
}
